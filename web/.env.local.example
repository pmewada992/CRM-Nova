# Full base URL of this app — needed for absolute redirect URLs (e.g. Clerk invitations)
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Clerk (https://dashboard.clerk.com) — run `clerk env pull` to fill these in
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Dashboard > Webhooks > Add endpoint -> /api/webhooks/clerk, subscribe to user.created/updated/deleted
CLERK_WEBHOOK_SIGNING_SECRET=

# Supabase (https://app.supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
